{
	"schemaVersion": 1,
	"id": "${id}",
	"version": "${version}",
	"name": "${name}",
	"description": "${description}",
	"authors": [
		"lowercasebtw",
		"p1k0chu",
		"auri-f5bde6",
		"esoij"
	],
	"contact": {
		"sources": "${source}",
		"issues": "${issues}"
	},
	"license": "${license}",
	"icon": "assets/${id}/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			"io.github.cutecarsmc.client.CuteCarsClient"
		],
		"main": [
			"io.github.cutecarsmc.CuteCarsMain"
		],
		"modmenu": [
			"io.github.cutecarsmc.client.config.ModMenuIntegration"
		],
		"fabric-datagen": [
			"io.github.cutecarsmc.client.datagen.CuteCarsDataGenerator"
		]
	},
	"mixins": [
		"cutecars.mixins.json",
		{
			"environment": "client",
			"config": "cutecars-client.mixins.json"
		}
	],
	"depends": {
		"fabricloader": ">=${fabric_loader_version}",
		"minecraft": "${minecraft_version_range}",
		"fabric-api": "*"
	},
	"custom": {
		"modmenu": {
			"links": {
				"modmenu.discord": "${discord}",
				"modmenu.modrinth": "${modrinth}",
				"modmenu.curseforge": "${curseforge}"
			},
			"update_checker": true
		}
	}
}
